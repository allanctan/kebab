KEBAB_KNOWLEDGE_DIR=./knowledge
KEBAB_RAW_DIR=./knowledge/raw
KEBAB_PROCESSED_DIR=./knowledge/processed
KEBAB_CURATED_DIR=./knowledge/curated
KEBAB_QDRANT_PATH=./knowledge/.qdrant
# KEBAB_QDRANT_URL=http://localhost:6333
KEBAB_QDRANT_COLLECTION=knowledge

# Gemini credentials & defaults
KEBAB_GOOGLE_API_KEY=
KEBAB_GEMINI_MODEL=google-gla:gemini-2.5-flash
KEBAB_FAST_MODEL=google-gla:gemini-2.5-flash-lite
KEBAB_EVAL_MODEL=google-gla:gemini-2.5-flash
KEBAB_LLM_MAX_RETRIES=5

# Curation / verification model strings (accept $VAR references)
KEBAB_LLM_CURATION_MODEL=$GEMINI_MODEL
KEBAB_LLM_VERIFICATION_MODELS=["$GEMINI_MODEL","$FAST_MODEL"]
KEBAB_EMBEDDING_MODEL=text-embedding-004

KEBAB_MAX_TOKENS_PER_ARTICLE=50000
KEBAB_LOGS_DIR=./logs
# KEBAB_LOGFIRE_TOKEN=
KEBAB_LOGFIRE_ENVIRONMENT=local
